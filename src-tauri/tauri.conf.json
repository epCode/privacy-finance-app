{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Personal Finance Tracker",
  "version": "0.1.0",
  "identifier": "com.personalfinancetracker.app",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Personal Finance Tracker",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
